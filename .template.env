# These settings are NOT suited for production.
# They are intented for development.

###
### airflow
###

# AIRFLOW_UID should be equal to $(id -u)
# cf https://airflow.apache.org/docs/apache-airflow/stable/howto/docker-compose/index.html#setting-the-right-airflow-user
AIRFLOW_UID=

AIRFLOW_HOME=.

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://airflow:airflow@localhost:5432/airflow
AIRFLOW__CORE__DEFAULT_TIMEZONE=Europe/Paris

AIRFLOW_CONN_PG=postgresql://data-inclusion:data-inclusion@localhost:5433/data-inclusion

# airflow connections string *must* be urlencoded (using `urllib.parse.urlencode` for instance)

AIRFLOW_VAR_DATAGOUV_API_KEY=
AIRFLOW_VAR_BREVO_API_KEY=
AIRFLOW_VAR_DORA_API_TOKEN=
AIRFLOW_VAR_DORA_PREPROD_API_TOKEN=
AIRFLOW_VAR_FT_API_TOKEN=
AIRFLOW_VAR_EMPLOIS_API_TOKEN=
AIRFLOW_VAR_SOLIGUIDE_API_TOKEN=
AIRFLOW_VAR_MA_BOUSSOLE_AIDANTS_API_KEY=

###
### datawarehouse
###

###
### api
###

API_ENV=dev
API_DEBUG=False
